          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "id": 101,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "$loki_datasource" },
          "editorMode": "code",
          "expr": "sum by (log_channel) (rate({namespace=~\"$namespace\", job=~\"$job\", app=~\"$app\"} | json | __error__=\"\" [$__interval]))",
          "legendFormat": "{{log_channel}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Log Rate by Channel",
      "type": "timeseries"
    },

